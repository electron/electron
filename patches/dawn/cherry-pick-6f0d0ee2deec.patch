diff --git a/src/dawn/common/MutexProtected.h b/src/dawn/common/MutexProtected.h
index 48e22e693a111d602e6e23102923b84eed5a5132..be96e563d36b2b11e139177fd9056a958249656c 100644
--- a/src/dawn/common/MutexProtected.h
+++ b/src/dawn/common/MutexProtected.h
@@ -174,7 +174,7 @@ class CondVarGuard : public NonMovable, StackAllocated {
                  typename Traits::MutexType& mutex,
                  class Defer* defer = nullptr,
                  std::condition_variable* cv = nullptr)
-        : mNotifyScope(cv), mGuard(obj, mutex, defer) {}
+        : mGuard(obj, mutex, defer), mNotifyScope(cv) {}
 
     auto* Get() const { return mGuard.Get(); }
 
@@ -193,8 +193,11 @@ class CondVarGuard : public NonMovable, StackAllocated {
 
         raw_ptr<std::condition_variable> cv = nullptr;
     };
-    NotifyScope mNotifyScope;
+    // Note that the Guard must be before the NotifyScope so that the C++ member destruction order
+    // signals the condition variable before unlocking the mutex. This keeps all uses of the
+    // condition variable guarded by the mutex.
     Guard<T, Traits> mGuard;
+    NotifyScope mNotifyScope;
 };
 
 template <typename T, typename Traits, template <typename, typename> class Guard = detail::Guard>
