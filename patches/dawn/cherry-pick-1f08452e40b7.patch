+)";
+    EXPECT_EQ(src, str());
+
+    auto* expect = R"(
+%foo = func(%u:i32):void {
+  $B1: {
+    %3:i32 = subgroupMax %u
+    ret
+  }
+}
+)";
+
+    Run(CollapseSubgroupMinMax);
+    EXPECT_EQ(expect, str());
+}
