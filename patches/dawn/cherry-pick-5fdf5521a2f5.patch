--- a/src/dawn/tests/end2end/ShaderTests.cpp
+++ b/src/dawn/tests/end2end/ShaderTests.cpp
@@ -1226,6 +1226,52 @@ TEST_P(ShaderTests, ShaderOverridingRobustnessBuiltins) {
