diff --git a/ui/gtk/gtk_util.cc b/ui/gtk/gtk_util.cc
index 6e5ddad561df9260ebaaad10bf7e5d0127472481..8002e0b3c9733056dc6e3b5439f7c6b910cad42b 100644
--- a/ui/gtk/gtk_util.cc
