@@ -89,6 +89,9 @@ class COMPONENT_EXPORT(UI_BASE_X) XCursorLoader {
   base::WeakPtrFactory<XCursorLoader> weak_factory_{this};
 };
 
+COMPONENT_EXPORT(UI_BASE_X)
