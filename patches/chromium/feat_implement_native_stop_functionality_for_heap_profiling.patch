+void ProfilingClient::StopProfiling(StopProfilingCallback callback) {
+  if (!started_profiling_) {
+    std::move(callback).Run();
+    return;
+  }
+
+  base::SamplingHeapProfiler::Get()->Stop();
+  started_profiling_ = false;
+  std::move(callback).Run();
+}
