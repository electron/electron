--- a/components/heap_profiling/multi_process/supervisor.cc
+++ b/components/heap_profiling/multi_process/supervisor.cc
@@ -72,6 +72,13 @@ void Supervisor::Start(Mode mode,
                        base::OnceClosure closure) {
   DCHECK(content::BrowserThread::CurrentlyOn(content::BrowserThread::UI));
   DCHECK(!started_);
+
+  if (has_core_initialized_) {
+    FinishInitializationOnUIhread(mode, std::move(closure),
+                                  controller_weak_ptr_);
+    return;
+  }
+
   base::trace_event::MemoryDumpManager::GetInstance()
       ->GetDumpThreadTaskRunner()
       ->PostTask(FROM_HERE,
@@ -80,6 +87,24 @@ void Supervisor::Start(Mode mode,
                                 sampling_rate, std::move(closure)));
 }
 
+void Supervisor::Stop(base::OnceCallback<void(bool)> callback) {
+  DCHECK(content::BrowserThread::CurrentlyOn(content::BrowserThread::UI));
+
+  if (!started_) {
+    std::move(callback).Run(false);
+    return;
+  }
+
+  // Stop observing/connecting new processes immediately while shutdown is in
+  // flight.
+  client_connection_manager_.reset();
+
+  content::GetIOThreadTaskRunner({})->PostTask(
+      FROM_HERE,
+      base::BindOnce(&Supervisor::StopOnIOThread, base::Unretained(this),
+                     std::move(callback)));
+}
+
 void Supervisor::StartProfilingOnMemoryInfraThread(Mode mode,
                                                    mojom::StackMode stack_mode,
                                                    uint32_t sampling_rate,
@@ -215,6 +240,10 @@ void Supervisor::FinishInitializationOnUIhread(
   DCHECK(content::BrowserThread::CurrentlyOn(content::BrowserThread::UI));
   DCHECK(!started_);
   started_ = true;
+  if (!has_core_initialized_) {
+    has_core_initialized_ = true;
+    controller_weak_ptr_ = controller_weak_ptr;
+  }
 
   if (constructor_) {
     client_connection_manager_ = (*constructor_)(controller_weak_ptr, mode);
@@ -241,4 +270,34 @@ void Supervisor::GetProfiledPidsOnIOThread(GetProfiledPidsCallback callback) {
   controller_->GetProfiledPids(std::move(post_result_to_ui_thread));
 }
 
+void Supervisor::StopOnIOThread(base::OnceCallback<void(bool)> callback) {
+  DCHECK(content::BrowserThread::CurrentlyOn(content::BrowserThread::IO));
+
+  if (!controller_) {
+    content::GetUIThreadTaskRunner({})->PostTask(
+        FROM_HERE, base::BindOnce(std::move(callback), false));
+    return;
+  }
+
+  controller_->StopProfilingAllClients(base::BindOnce(
+      [](Supervisor* supervisor, base::OnceCallback<void(bool)> callback,
+         bool success) {
+        DCHECK(content::BrowserThread::CurrentlyOn(content::BrowserThread::IO));
+        content::GetUIThreadTaskRunner({})->PostTask(
+            FROM_HERE,
+            base::BindOnce(
+                [](Supervisor* supervisor,
+                   base::OnceCallback<void(bool)> callback,
+                   bool success) {
+                  DCHECK(content::BrowserThread::CurrentlyOn(
+                      content::BrowserThread::UI));
+                  if (success)
+                    supervisor->started_ = false;
+                  std::move(callback).Run(success);
+                },
+                supervisor, std::move(callback), success));
+      },
+      base::Unretained(this), std::move(callback)));
+}
+
 }  // namespace heap_profiling
