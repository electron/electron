   gint size = 0;
   g_object_get(gtk_settings_get_default(), "gtk-cursor-theme-size", &size,
@@ -819,6 +853,9 @@ gfx::Size GtkUi::GetPdfPaperSize(printing::PrintingContextLinux* context) {
