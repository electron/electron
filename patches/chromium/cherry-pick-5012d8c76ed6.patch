+bool IsValidIconThemeName(const QString& theme) {
+  if (theme.isEmpty() || theme == "." || theme == "..") {
+    return false;
+  }
+  if (theme.contains('/') || theme.contains('\\') || theme.contains("..")) {
+    return false;
+  }
+  return true;
+}
