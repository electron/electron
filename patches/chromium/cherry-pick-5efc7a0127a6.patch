                     : CSSPropertyName(id);
     return unsupported_style_value->IsValidFor(name);
   }
-  if (value.GetType() == CSSStyleValue::kUnparsedType) {
-    return true;
+  if (auto* unparsed_value = DynamicTo<CSSUnparsedValue>(value)) {
