From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: deepak1556 <hop2deep@gmail.com>
Date: Sat, 11 Jul 2026 22:31:49 +0900
Subject: fix: disable ICF for v8_context_snapshot_generator when using mold

Fixes the following startup crash from mismatched external references

```
```

Should be upstreamed. Refs https://issues.chromium.org/issues/40208899#comment94.

diff --git a/tools/v8_context_snapshot/BUILD.gn b/tools/v8_context_snapshot/BUILD.gn
index ec2357139826613e8b295cb01be341acb03b4737..835527bbdd8f3ad0cd59e67179b0c7b1bd5eadc9 100644
--- a/tools/v8_context_snapshot/BUILD.gn
+++ b/tools/v8_context_snapshot/BUILD.gn
@@ -122,7 +122,7 @@ if (use_v8_context_snapshot) {
       ldflags = [ "/OPT:NOICF" ]  # link.exe, but also lld-link.exe.
     } else if (is_apple && !use_lld) {
       ldflags = [ "-Wl,-no_deduplicate" ]  # ld64.
-    } else if (use_lld) {
+    } else if (use_lld || linker_path != "") {
       ldflags = [ "-Wl,--icf=none" ]
     }
   }
