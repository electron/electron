index 5d53d3bb72dddbbe0d8824215a51909adac3f732..52944d93a365c318dbc52b51cb45f824c95f515b 100644
--- a/components/dbus/xdg/systemd.h
+++ b/components/dbus/xdg/systemd.h
@@ -5,6 +5,9 @@
 #ifndef COMPONENTS_DBUS_XDG_SYSTEMD_H_
 #define COMPONENTS_DBUS_XDG_SYSTEMD_H_
 
+#include <string>
+#include <string_view>
+
 #include "base/functional/callback_forward.h"
 
 namespace dbus {
@@ -37,6 +40,13 @@ using SystemdUnitCallback = base::OnceCallback<void(SystemdUnitStatus)>;
 void SetSystemdScopeUnitNameForXdgPortal(dbus::Bus* bus,
                                          SystemdUnitCallback callback);
 
+// Escapes a string for use as a segment of a systemd unit name: bytes outside
+// [A-Za-z0-9:_.] become "\xNN", so consumers like xdg-desktop-portal can
+// unescape it losslessly and '-' can't be mistaken for a segment separator.
+// Unlike systemd-escape(1), '/' becomes "\x2f" (not '-') and a leading '.' is
+// kept; both still unescape correctly. Exposed for testing.
+std::string SystemdEscape(std::string_view name);
+
 }  // namespace dbus_xdg::internal
 
 #endif  // COMPONENTS_DBUS_XDG_SYSTEMD_H_
diff --git a/components/dbus/xdg/systemd_unittest.cc b/components/dbus/xdg/systemd_unittest.cc
index 4a925983fa84d8dec1d260f96d79d58132de2fb7..5ca114ce94eb9b6c39122ceb2d7536e803f6b931 100644
--- a/components/dbus/xdg/systemd_unittest.cc
+++ b/components/dbus/xdg/systemd_unittest.cc
@@ -54,6 +54,21 @@ std::unique_ptr<dbus::Response> CreateActiveStateGetAllResponse(
 
 using SetSystemdScopeUnitNameForXdgPortalTest = ::testing::Test;
 
+TEST(SystemdEscapeTest, EscapesUnitNameSegment) {
+  // Reverse-DNS app ids are unchanged.
+  EXPECT_EQ(internal::SystemdEscape("com.example.MyApp"), "com.example.MyApp");
+  EXPECT_EQ(internal::SystemdEscape("org.chromium.Chromium"),
+            "org.chromium.Chromium");
+  // Bytes outside [A-Za-z0-9:_.] are escaped so '-' can't be mistaken for a
+  // unit name separator.
+  EXPECT_EQ(internal::SystemdEscape("my-app"), "my\\x2dapp");
+  EXPECT_EQ(internal::SystemdEscape("my app"), "my\\x20app");
+  EXPECT_EQ(internal::SystemdEscape("app_1:2.3"), "app_1:2.3");
+  // Non-ASCII bytes must not be sign-extended.
+  EXPECT_EQ(internal::SystemdEscape("caf\xc3\xa9"), "caf\\xc3\\xa9");
+  EXPECT_EQ(internal::SystemdEscape(""), "");
+}
