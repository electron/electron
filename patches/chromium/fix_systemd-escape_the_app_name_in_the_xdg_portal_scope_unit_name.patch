From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Keeley Hammond <vertedinde@electronjs.org>
Date: Wed, 1 Jul 2026 20:27:12 +0000
Subject: fix: systemd-escape the app name in the xdg portal scope unit name

components/dbus/xdg/systemd.cc builds the transient scope name
app-<name>-<pid>.scope without escaping <name>. Per
https://systemd.io/DESKTOP_ENVIRONMENTS/ (and matching what gnome-shell
does for launcher-created scopes), the app id segment must be escaped
so that unescaping round-trips: bytes outside [A-Za-z0-9:_.] become
\xNN.

Without this, a dashed name like my-app produces app-my-app-1234.scope,
which xdg-desktop-portal (xdp-app-info-host.c) parses as launcher="my",
app id="app" - the wrong identity. GNOME 50.0/50.1 then rejects
GlobalShortcuts binds for such ids because they fail
g_application_id_is_valid(). The reverse-DNS ids that GetAppName()
returns for stock Chromium builds contain no bytes that need escaping,
so their scope names are unchanged.

This patch should be submitted upstream.

diff --git a/components/dbus/xdg/systemd.cc b/components/dbus/xdg/systemd.cc
index 03250c4411fae1db02a7a675bff7ae669cce097d..3ead083d9648a64371dff332206ee49d51c86d99 100644
--- a/components/dbus/xdg/systemd.cc
+++ b/components/dbus/xdg/systemd.cc
@@ -192,7 +192,8 @@ void OnNameHasOwnerResponse(scoped_refptr<dbus::Bus> bus,
   // The unit naming format is specified in
   // https://systemd.io/DESKTOP_ENVIRONMENTS/
   auto unit_name = base::ReplaceStringPlaceholders(
-      kUnitNameFormat, {app_name, base::NumberToString(pid)}, nullptr);
+      kUnitNameFormat,
+      {internal::SystemdEscape(app_name), base::NumberToString(pid)}, nullptr);
 
   auto* systemd = bus->GetObjectProxy(kServiceNameSystemd,
                                       dbus::ObjectPath(kObjectPathSystemd));
@@ -220,6 +221,21 @@ void OnNameHasOwnerResponse(scoped_refptr<dbus::Bus> bus,
 
 namespace internal {
 
+std::string SystemdEscape(std::string_view name) {
+  std::string escaped;
+  escaped.reserve(name.size());
+  for (char c : name) {
+    if (base::IsAsciiAlphaNumeric(c) || c == ':' || c == '_' || c == '.') {
+      escaped += c;
+    } else {
+      escaped += "\\x";
+      base::AppendHexEncodedByte(static_cast<uint8_t>(c), escaped,
+                                 /*uppercase=*/false);
+    }
+  }
+  return escaped;
+}
+
 void SetSystemdScopeUnitNameForXdgPortal(dbus::Bus* bus,
                                          SystemdUnitCallback callback) {
 #if DCHECK_IS_ON()
