 }
 
+std::optional<mojo_base::BigBuffer>
+ContentBrowserClient::GetExtraCreateNewWindowReplyData(
+    RenderFrameHost* new_window_main_frame,
+    const GURL& target_url) {
+  return std::nullopt;
+}
