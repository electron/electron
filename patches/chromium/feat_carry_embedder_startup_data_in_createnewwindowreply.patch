index ab9aeb852e5ea89583284386d9a78a3e3e17a310..cd5499f262ea5e9003f87185461e0272fdce608a 100644
--- a/content/common/frame.mojom
+++ b/content/common/frame.mojom
@@ -13,6 +13,7 @@ import "content/public/common/window_container_type.mojom";
 import "ipc/constants.mojom";
 import "mojo/public/mojom/base/file_path.mojom";
 import "mojo/public/mojom/base/time.mojom";
+import "mojo/public/mojom/base/big_buffer.mojom";
 import "mojo/public/mojom/base/unguessable_token.mojom";
 import "skia/public/mojom/skcolor.mojom";
 import "services/network/public/mojom/attribution.mojom";
@@ -694,6 +695,14 @@ struct CreateNewWindowReply {
   // Initial window geometry.
   gfx.mojom.Rect? widget_screen_rect;
   gfx.mojom.Rect? window_screen_rect;
+
+  // Extra field added by Electron. Carries the new window's preload startup
+  // data (an opaque embedder blob) so its synchronous about:blank document can
+  // run the preload that the embedder may have overridden — the about:blank's
+  // DidCreateScriptContext fires entirely renderer-side before any other
+  // browser-to-renderer transport can reach the new frame. Populated by
+  // ContentBrowserClient::GetExtraCreateNewWindowReplyData; may be null.
+  mojo_base.mojom.BigBuffer? electron_startup_data;
 };
 
 // A per-navigation interface passed along with the BeginNavigation call, used
