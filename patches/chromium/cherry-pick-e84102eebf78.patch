   if (size_changed) {
     delegate_->HandleClientSizeChanged(GetClientAreaBounds().size());
   }
@@ -206,6 +222,8 @@ void HWNDMessageHandlerHeadless::Show(ui::mojom::WindowShowState show_state,
 
