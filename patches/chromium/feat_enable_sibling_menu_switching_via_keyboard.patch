+++ b/ui/views/controls/menu/menu_controller.h
@@ -567,6 +567,15 @@ class VIEWS_EXPORT MenuController final : public gfx::AnimationDelegate,
   // If possible, closes the submenu.
   void CloseSubmenu();
 
+  // Like OpenSubmenuChangeSelectionIfCan(), but if the selected item has no
+  // submenu to open, asks the delegate to switch to the next sibling menu.
+  void OpenSubmenuOrSwitchSiblingMenu();
+
+  // Like CloseSubmenu(), but if there is no submenu to close (i.e. the
+  // selection is at the top level of the menu), asks the delegate to switch to
+  // the previous sibling menu.
+  void CloseSubmenuOrSwitchSiblingMenu();
+
   // Show a context menu for the currently hot-tracked view if available.
   // Triggered by keyboard events, e.g., APPS key, Shift+F10.
   void ShowContextMenu();
