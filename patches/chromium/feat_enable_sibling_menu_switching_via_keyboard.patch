@@ -3324,6 +3324,52 @@ void MenuController::CloseSubmenu() {
   }
 }
 
+void MenuController::OpenSubmenuOrSwitchSiblingMenu() {
+  MenuItemView* const selected = pending_state_.item;
+  // If the selected item can open a submenu, open it as usual.
+  if (selected && selected->HasSubmenu() && selected->GetEnabled()) {
+    OpenSubmenuChangeSelectionIfCan();
+    return;
+  }
+  // Otherwise, only switch to the next sibling menu when the selection
+  // is a direct child of the root menu. Switching is not allowed from
+  // within a nested submenu.
+  const bool is_top_level_child =
+      selected && !selected->HasSubmenu() && selected->GetParentMenuItem() &&
+      !selected->GetParentMenuItem()->GetParentMenuItem();
+  if (is_top_level_child && selected->GetDelegate() &&
+      selected->GetDelegate()->GetSiblingMenuByDirection(/*next=*/true)) {
+    return;
+  }
+  OpenSubmenuChangeSelectionIfCan();
+}
+
+void MenuController::CloseSubmenuOrSwitchSiblingMenu() {
+  MenuItemView* item = state_.item;
+  // If there is a submenu to close, close it as usual.
+  const bool can_close_submenu =
+      item && item->GetParentMenuItem() &&
+      (item->SubmenuIsShowing() ||
+       item->GetParentMenuItem()->GetParentMenuItem());
+  if (can_close_submenu) {
+    CloseSubmenu();
+    return;
+  }
+  // Otherwise, only switch to the previous sibling menu when the selection is a
+  // direct child of the root menu. Use pending_state_.item, not state_.item:
+  // keyboard selection of a submenu item defers the state_ commit, so state_
+  // may still point at the previously selected leaf.
+  MenuItemView* const selected = pending_state_.item;
+  const bool is_top_level_child =
+      selected && !selected->HasSubmenu() && selected->GetParentMenuItem() &&
+      !selected->GetParentMenuItem()->GetParentMenuItem();
+  if (is_top_level_child && selected->GetDelegate() &&
+      selected->GetDelegate()->GetSiblingMenuByDirection(/*next=*/false)) {
+    return;
+  }
+  CloseSubmenu();
+}
+
 MenuController::SelectByCharDetails MenuController::FindChildForMnemonic(
     MenuItemView* parent,
     char16_t key,
diff --git a/ui/views/controls/menu/menu_controller.h b/ui/views/controls/menu/menu_controller.h
