--- a/ui/views/controls/menu/menu_delegate.h
+++ b/ui/views/controls/menu/menu_delegate.h
@@ -201,6 +201,13 @@ class VIEWS_EXPORT MenuDelegate {
                                        bool* has_mnemonics,
                                        MenuButton** button);
 
+  // Invoked when the user presses the left/right arrow keys while at the top
+  // level of a menu (e.g. an application menu bar) and there is no submenu to
+  // open or close in that direction. |next| is true to switch to the next
+  // sibling menu and false for the previous one. Returns true if the delegate
+  // handled the request by switching menus.
+  virtual bool GetSiblingMenuByDirection(bool next);
+
   // Returns the max width menus can grow to be.
   virtual int GetMaxWidthForMenu(MenuItemView* menu);
 
