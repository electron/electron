From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Michaela Laurencin <mlaurencin@electronjs.org>
Date: Thu, 2 Jul 2026 20:32:59 -0400
Subject: feat: enable sibling menu switching via keyboard

Allow Left/Right arrow keys to move between adjacent top-level menus (e.g. an application menu bar)
while a menu is open, matching native platform behavior on Windows and Linux.
Adds MenuDelegate::GetSiblingMenuByDirection, invoked from MenuController when the user presses
Left/Right at the top level with nothing to open or close in that direction.

diff --git a/ui/views/controls/menu/menu_controller.cc b/ui/views/controls/menu/menu_controller.cc
index 79c89cde2a9dddbe9b2880c1599154b3ba041872..42c9ad0cfc4ac65681d566ce45768fe39b14e38a 100644
--- a/ui/views/controls/menu/menu_controller.cc
+++ b/ui/views/controls/menu/menu_controller.cc
@@ -1970,9 +1970,9 @@ bool MenuController::OnKeyPressed(const ui::KeyEvent& event) {
         break;
       }
       if (base::i18n::IsRTL()) {
-        CloseSubmenu();
+        CloseSubmenuOrSwitchSiblingMenu();
       } else {
-        OpenSubmenuChangeSelectionIfCan();
+        OpenSubmenuOrSwitchSiblingMenu();
       }
       break;
 
@@ -1981,9 +1981,9 @@ bool MenuController::OnKeyPressed(const ui::KeyEvent& event) {
         break;
       }
       if (base::i18n::IsRTL()) {
-        OpenSubmenuChangeSelectionIfCan();
+        OpenSubmenuOrSwitchSiblingMenu();
