@@ -163,6 +164,14 @@ struct EmbeddedWorkerStartParams {
   // Used to check whether the ServiceWorker has access to cross-origin
   // isolated APIs or not.
   bool cross_origin_isolated;
+
+  // Added by Electron. Opaque embedder blob (a serialized
+  // electron.mojom.RendererStartupData) carrying the service-worker preload
