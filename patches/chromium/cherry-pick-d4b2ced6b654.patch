+  // Task with correct ID should run.
+  EXPECT_EQ(0u, client->count());
+  client->PostBoundTaskWithExplicitId(id1, kFirstRunner);
+  client->PostBoundSignalTaskWithExplicitId(id1, kFirstRunner);
+  WaitEvent();
+  EXPECT_EQ(2u, client->count());
+
