+  std::unique_ptr<TaskServiceClient> client =
+      std::make_unique<TaskServiceClient>(task_service());
+
+  EXPECT_TRUE(client->Bind());
+  TaskService::InstanceId id1 = client->instance_id();
+  EXPECT_NE(TaskService::kInvalidInstanceId, id1);
