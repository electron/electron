+      deps += [ "//third_party/libsecret" ]
+      defines += [ "USE_LIBSECRET" ]
+    }
+    if (use_dbus) {
+      sources += [
+        "key_storage_kwallet_unittest.cc",
+        "kwallet_dbus_unittest.cc",
+      ]
+      deps += [ "//dbus:test_support" ]
+      defines += [ "USE_KWALLET" ]
