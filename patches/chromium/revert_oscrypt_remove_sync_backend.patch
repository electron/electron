+
+  configs += [ "//build/config/compiler:wexit_time_destructors" ]
+  defines = [ "IS_OS_CRYPT_IMPL" ]
+
+  if (allow_runtime_configurable_key_storage) {
+    defines += [ "ALLOW_RUNTIME_CONFIGURABLE_KEY_STORAGE" ]
