+#endif  // (BUILDFLAG(IS_LINUX) && !BUILDFLAG(IS_CASTOS))
+ private:
+#if BUILDFLAG(IS_APPLE)
+  // Return the keychain to use for accessing the encryption key.
+  crypto::apple::KeychainV2* GetKeychain();
+
