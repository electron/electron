From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Sam Attard <sattard@anthropic.com>
Date: Sun, 31 May 2026 00:51:17 +0000
Subject: build: fix profile runtime path for Linux arm32 PGO instrumentation

The clang package ships the Linux arm32 profile runtime under the armv7
triple (lib/clang/<version>/lib/armv7-unknown-linux-gnueabihf/), but the
clang driver resolves the runtime path from the arm-linux-gnueabihf
target triple, which normalizes to a directory that does not exist in
the package. As a result, linking anything built with -fprofile-generate
fails for Linux arm32 targets:

  ld.lld: error: cannot open .../arm-unknown-linux-gnueabihf/libclang_rt.profile.a

Suppress the driver's automatic profile runtime resolution with
-noprofilelib and link the armv7 archive explicitly.

Upstream has never hit this because Chrome is not built for Linux arm32.
This patch can be upstreamed.

diff --git a/build/config/compiler/pgo/BUILD.gn b/build/config/compiler/pgo/BUILD.gn
index 37251f8e9ba3848b4f8bd1fc487b54d5905fb705..08e7db575cf6efb5cd5d6aaacace50f3792713de 100644
--- a/build/config/compiler/pgo/BUILD.gn
+++ b/build/config/compiler/pgo/BUILD.gn
@@ -42,6 +42,16 @@ config("pgo_instrumentation_flags") {
       # linking, and embeds the path to the profile runtime library as
       # dependent library into each object file.
       ldflags = [ "-fprofile-generate" ]
+
+      # The clang package ships the Linux arm32 profile runtime under the
+      # armv7 triple (armv7-unknown-linux-gnueabihf), but the driver resolves
+      # the runtime path from the arm-linux-gnueabihf target triple, which
+      # does not exist in the package. Suppress the automatic profile runtime
+      # and link the armv7 archive explicitly.
+      if (is_linux && current_cpu == "arm") {
+        ldflags += [ "-noprofilelib" ]
+        libs = [ "$clang_base_path/lib/clang/$clang_version/lib/armv7-unknown-linux-gnueabihf/libclang_rt.profile.a" ]
+      }
     }
   }
 }
