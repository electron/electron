From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Sam Attard <sattard@anthropic.com>
Date: Sun, 31 May 2026 00:51:17 +0000
Subject: build: fix profile runtime resolution for PGO instrumented builds

fixes where -fprofile-generate builds fail because the compiler or
driver references the profile runtime by a name that does not exist in
the clang package:

Windows cross-compiles: objects compiled by Linux clang embed
   /DEFAULTLIB:clang_rt.profile.lib (per-target runtime naming), but the
   Windows package ships the legacy layout
   (lib/windows/clang_rt.profile-<arch>.lib). Linking fails with:
     lld-link: error: could not open 'clang_rt.profile.lib'
   Native Windows compiles do not hit this because clang-cl checks the
   on-disk layout and embeds the legacy name; cross compiles always use
   the per-target name.

Suppress the automatic runtime reference (-noprofilelib /
/nodefaultlib:) and link the correctly-named archive explicitly.

Upstream has never hit this case: Chrome's instrumented Windows
builds compile natively on Windows.
This patch can be upstreamed.

diff --git a/build/config/compiler/pgo/BUILD.gn b/build/config/compiler/pgo/BUILD.gn
index 7a412483528f4342517c51ba5e07a56c68fea946..10d9c93e7360dac2fcb7dea43ad97ababf0aae40 100644
--- a/build/config/compiler/pgo/BUILD.gn
+++ b/build/config/compiler/pgo/BUILD.gn
@@ -42,6 +42,24 @@ config("pgo_instrumentation_flags") {
       # linking, and embeds the path to the profile runtime library as
       # dependent library into each object file.
       ldflags = [ "-fprofile-generate" ]
+    } else {
+      # Objects compiled on Linux cross-compile workers embed
+      # /DEFAULTLIB:clang_rt.profile.lib (the per-target runtime name), but
+      # the Windows clang package ships the legacy layout
+      # (lib/windows/clang_rt.profile-<arch>.lib), so the embedded reference
+      # cannot be resolved at link time. Ignore it and link the
+      # correctly-named archive explicitly.
+      ldflags = [ "/nodefaultlib:clang_rt.profile.lib" ]
+      if (current_cpu == "x64") {
+        _profile_rt_arch = "x86_64"
+      } else if (current_cpu == "x86") {
+        _profile_rt_arch = "i386"
+      } else if (current_cpu == "arm64") {
+        _profile_rt_arch = "aarch64"
+      } else {
+        assert(false, "unsupported target_cpu for PGO instrumentation")
+      }
+      libs = [ "$clang_base_path/lib/clang/$clang_version/lib/windows/clang_rt.profile-${_profile_rt_arch}.lib" ]
     }
   }
 }
