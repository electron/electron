From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Alice Zhao <alicelovescake@anthropic.com>
Date: Sun, 21 Dec 2025 09:58:47 -0800
Subject: fix: suppress nodiscard warning for copy_options |= operator

libc++ added [[nodiscard]] to std::filesystem::copy_options operator|=
which causes build failures with -Werror.

diff --git a/src/node_file.cc b/src/node_file.cc
index 56b6cd5c39d5e72efd24b7aba1f28dab91a6144e..adac1a04793cc9876c46a508e5c6e5241697311c 100644
--- a/src/node_file.cc
+++ b/src/node_file.cc
@@ -3501,11 +3501,11 @@ static void CpSyncCopyDir(const FunctionCallbackInfo<Value>& args) {
 
   auto file_copy_opts = std::filesystem::copy_options::recursive;
   if (force) {
-    file_copy_opts |= std::filesystem::copy_options::overwrite_existing;
+    (void)(file_copy_opts |= std::filesystem::copy_options::overwrite_existing);
   } else if (error_on_exist) {
-    file_copy_opts |= std::filesystem::copy_options::none;
+    (void)(file_copy_opts |= std::filesystem::copy_options::none);
   } else {
-    file_copy_opts |= std::filesystem::copy_options::skip_existing;
+    (void)(file_copy_opts |= std::filesystem::copy_options::skip_existing);
   }
 
   std::function<bool(std::filesystem::path, std::filesystem::path)>
