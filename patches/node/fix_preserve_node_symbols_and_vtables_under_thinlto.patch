diff --git a/src/node_http2.h b/src/node_http2.h
index 28245d7b98e06bee467c5f91dd9caf1cfdbfdda0..a4575619b26346d05ba9a1a4a245937a3b30b414 100644
--- a/src/node_http2.h
+++ b/src/node_http2.h
@@ -144,6 +144,96 @@ struct Http2RcBufferPointerTraits {
 using Http2Headers = NgHeaders<Http2HeadersTraits>;
 using Http2RcBufferPointer = NgRcBufPointer<Http2RcBufferPointerTraits>;
 
+}  // namespace http2
+
+// ThinLTO: class template instantiations always have weak (linkonce_odr)
+// vtables. On Mach-O, LTO localizes weak unnamed_addr vtables during code
+// generation even when other LTO partitions still reference them, which
+// fails the link with undefined vtable symbols. This explicit specialization
+// is an ordinary class that can have a key function (the out-of-line
+// destructor), so its vtable is a strong symbol that ThinLTO must keep
+// external. The body is otherwise identical to the primary template in
+// node_http_common.h.
+template <>
+class NgRcBufPointer<http2::Http2RcBufferPointerTraits>::External
+    : public v8::String::ExternalOneByteStringResource {
+ public:
+  explicit External(
+      const NgRcBufPointer<http2::Http2RcBufferPointerTraits>& ptr)
+      : ptr_(ptr) {}
+
+  // Key function; defined in node_http2.cc to anchor the vtable.
+  ~External() override;
+
+  const char* data() const override {
+    return const_cast<const char*>(reinterpret_cast<char*>(ptr_.data()));
+  }
+
+  size_t length() const override {
+    return ptr_.len();
+  }
+
+  static inline
+  v8::MaybeLocal<v8::String> GetInternalizedString(
+      Environment* env,
+      const NgRcBufPointer<http2::Http2RcBufferPointerTraits>& ptr) {
+    return v8::String::NewFromOneByte(
+        env->isolate(),
+        ptr.data(),
+        v8::NewStringType::kInternalized,
+        ptr.len());
+  }
+
+  template <typename Allocator>
+  static v8::MaybeLocal<v8::String> New(
+      Allocator* allocator,
+      NgRcBufPointer<http2::Http2RcBufferPointerTraits> ptr) {
+    Environment* env = allocator->env();
+    if (ptr.IsStatic()) {
+      auto& static_str_map = env->isolate_data()->static_str_map;
+      const char* header_name = reinterpret_cast<const char*>(ptr.data());
+      v8::Eternal<v8::String>& eternal = static_str_map[header_name];
+      if (eternal.IsEmpty()) {
+        v8::Local<v8::String> str;
+        if (!GetInternalizedString(env, ptr).ToLocal(&str)) {
+          ptr.reset();
+          return {};
+        }
+        eternal.Set(env->isolate(), str);
+        return str;
+      }
+      return eternal.Get(env->isolate());
+    }
+
+    size_t len = ptr.len();
+
+    if (len == 0) {
+      ptr.reset();
+      return v8::String::Empty(env->isolate());
+    }
+
+    if (ptr.IsInternalizable() && len < 64) {
+      v8::MaybeLocal<v8::String> ret = GetInternalizedString(env, ptr);
+      ptr.reset();
+      return ret;
+    }
+
+    allocator->StopTrackingMemory(ptr.get());
+    External* h_str = new External(std::move(ptr));
+    v8::MaybeLocal<v8::String> str =
+        v8::String::NewExternalOneByte(env->isolate(), h_str);
+    if (str.IsEmpty())
+      delete h_str;
+
+    return str;
+  }
+
+ private:
+  NgRcBufPointer<http2::Http2RcBufferPointerTraits> ptr_;
+};
+
+namespace http2 {
+
 struct NgHttp2StreamWrite : public MemoryRetainer {
   BaseObjectPtr<AsyncWrap> req_wrap;
   uv_buf_t buf;
diff --git a/src/node_union_bytes.h b/src/node_union_bytes.h
index 4a3f67980fdc925699cc67e40736bddce8f7b857..c8e69ea97ab3c79f395b029be711902d1395dd56 100644
--- a/src/node_union_bytes.h
+++ b/src/node_union_bytes.h
@@ -41,6 +41,81 @@ class StaticExternalByteResource : public Base {
   std::shared_ptr<void> owning_ptr_;
 };
 
+// ThinLTO: class template instantiations always have weak (linkonce_odr)
+// vtables. On Mach-O, LTO localizes weak unnamed_addr vtables during code
+// generation even when other LTO partitions still reference them, which
+// fails the link with undefined vtable symbols. These explicit
+// specializations are ordinary classes that can have key functions (the
+// out-of-line destructor), so their vtables are strong symbols that ThinLTO
+// must keep external. The bodies are identical to the primary template.
+template <>
+class StaticExternalByteResource<uint8_t,
+                                 char,
+                                 v8::String::ExternalOneByteStringResource>
+    : public v8::String::ExternalOneByteStringResource {
+ public:
+  explicit StaticExternalByteResource(const uint8_t* data,
+                                      size_t length,
+                                      std::shared_ptr<void> owning_ptr)
+      : data_(data), length_(length), owning_ptr_(owning_ptr) {}
+
+  // Key function; defined in node_builtins.cc to anchor the vtable.
+  ~StaticExternalByteResource() override;
+
+  const char* data() const override {
+    return reinterpret_cast<const char*>(data_);
+  }
+  size_t length() const override { return length_; }
+
+  void Dispose() override {
+    // We ignore Dispose calls from V8, even if we "own" a resource via
+    // owning_ptr_. All instantiations of this class are static or owned by a
+    // static map, and will be destructed when static variables are destructed.
+  }
+
+  StaticExternalByteResource(const StaticExternalByteResource&) = delete;
+  StaticExternalByteResource& operator=(const StaticExternalByteResource&) =
+      delete;
+
+ private:
+  const uint8_t* data_;
+  const size_t length_;
+  std::shared_ptr<void> owning_ptr_;
+};
+
+template <>
+class StaticExternalByteResource<uint16_t,
+                                 uint16_t,
+                                 v8::String::ExternalStringResource>
+    : public v8::String::ExternalStringResource {
+ public:
+  explicit StaticExternalByteResource(const uint16_t* data,
+                                      size_t length,
+                                      std::shared_ptr<void> owning_ptr)
+      : data_(data), length_(length), owning_ptr_(owning_ptr) {}
+
+  // Key function; defined in node_builtins.cc to anchor the vtable.
+  ~StaticExternalByteResource() override;
+
+  const uint16_t* data() const override { return data_; }
+  size_t length() const override { return length_; }
+
+  void Dispose() override {
+    // We ignore Dispose calls from V8, even if we "own" a resource via
+    // owning_ptr_. All instantiations of this class are static or owned by a
+    // static map, and will be destructed when static variables are destructed.
+  }
+
+  StaticExternalByteResource(const StaticExternalByteResource&) = delete;
+  StaticExternalByteResource& operator=(const StaticExternalByteResource&) =
+      delete;
+
+ private:
+  const uint16_t* data_;
+  const size_t length_;
+  std::shared_ptr<void> owning_ptr_;
+};
+
 using StaticExternalOneByteResource =
     StaticExternalByteResource<uint8_t,
                                char,
