--- a/tools/snapshot/node_mksnapshot.cc
+++ b/tools/snapshot/node_mksnapshot.cc
@@ -1,7 +1,8 @@
 #include <cstdio>
+#include <cstdlib>
 #include <iostream>
-#include <sstream>
 #include <string>
+#include <string_view>
 #include <vector>
 
 #include "libplatform/libplatform.h"
@@ -61,6 +62,41 @@ int BuildSnapshot(int argc, char* argv[]) {
     return 1;
   }
 
+  // Electron: when V8 is built with external startup data (Chromium's V8),
+  // the snapshot creator cannot build the heap from scratch (that requires
+  // V8's full setup-isolate delegate, only linked by V8's own mksnapshot).
+  // Instead load the V8 startup snapshot and extend it -- exactly how
+  // v8_context_snapshot_generator builds the blink context snapshot. The
+  // build passes --electron-v8-snapshot-blob=<path>; strip it from argv
+  // (so node's CLI parser doesn't see it) and load it before V8 init.
+  {
+    static std::string blob_bytes;  // must outlive the SnapshotCreator
+    static v8::StartupData base_blob{nullptr, 0};
+    std::vector<char*> filtered;
+    const std::string kFlag = "--electron-v8-snapshot-blob=";
+    for (int i = 0; i < argc; ++i) {
+      if (std::string_view(argv[i]).substr(0, kFlag.size()) == kFlag) {
+        const char* path = argv[i] + kFlag.size();
+        if (const int r = node::ReadFileSync(&blob_bytes, path); r != 0) {
+          std::cerr << "Cannot read V8 snapshot blob " << path << ": "
+                    << uv_strerror(r) << "\n";
+          return 1;
+        }
+        base_blob.data = blob_bytes.data();
+        base_blob.raw_size = static_cast<int>(blob_bytes.size());
+        node::SnapshotBuilder::SetBaseSnapshotForCreation(&base_blob);
+      } else {
+        filtered.push_back(argv[i]);
+      }
+    }
+    if (static_cast<int>(filtered.size()) != argc) {
+      argc = static_cast<int>(filtered.size());
+      for (int i = 0; i < argc; ++i)
+        argv[i] = filtered[i];
+      argv[argc] = nullptr;
+    }
+  }
+
   std::shared_ptr<node::InitializationResult> result =
       node::InitializeOncePerProcess(
           std::vector<std::string>(argv, argv + argc),
