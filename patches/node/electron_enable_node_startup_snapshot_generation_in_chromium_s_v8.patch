diff --git a/src/node_snapshot_stub.cc b/src/node_snapshot_stub.cc
index 664f878c0671db76cbf68116d224606243ddf501..4ed6d6ecf12ea92129f4d7b7fdb59bcb056cf6a1 100644
--- a/src/node_snapshot_stub.cc
+++ b/src/node_snapshot_stub.cc
@@ -6,6 +6,17 @@
 
 namespace node {
 
+// Electron: the no-snapshot fallback for GetEmbeddedSnapshotData(). It lives
+// in its own ":node_snapshot_stub" source_set (not in libnode), so each target
+// links EXACTLY ONE provider of this symbol: the shipped framework and the
+// snapshot code-cache tool link ":node_snapshot" (the real embedded snapshot,
+// or this same stub when node_use_node_snapshot is off); every other libnode
+// consumer that does not -- node_mksnapshot (linking ":node_snapshot" would
+// cycle through run_node_mksnapshot), the standalone node CLI, the js2c
+// code-cache tool, node_cctest/node_embedtest -- links ":node_snapshot_stub".
+// Because no target links both providers, this can be a normal strong symbol
+// instead of a weak override; that is what makes it link on Windows, where
+// lld-link does not resolve duplicate weak symbols the way ld/ld64 do.
 const SnapshotData* SnapshotBuilder::GetEmbeddedSnapshotData() {
   return nullptr;
 }
