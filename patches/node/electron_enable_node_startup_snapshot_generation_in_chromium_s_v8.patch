diff --git a/src/node_builtins.cc b/src/node_builtins.cc
index ec1f9ce6ae7059faae6a5f727eff41b2b3fc489d..71226c74e5aa3d01603cce5852465a6fe011a9f7 100644
--- a/src/node_builtins.cc
+++ b/src/node_builtins.cc
@@ -662,12 +662,17 @@ bool BuiltinLoader::CompileAllBuiltinsAndCopyCodeCache(
 
 void BuiltinLoader::RefreshCodeCache(const std::vector<CodeCacheInfo>& in) {
   RwLock::ScopedLock lock(code_cache_->mutex);
-  code_cache_->map.reserve(in.size());
-  DCHECK(code_cache_->map.empty());
+  // Electron: this can be called more than once. Environment::Deserialize
+  // feeds the Node startup snapshot's own code cache (node-internal builtins,
+  // plus the electron/js2c/* bundles node_mksnapshot compiled while building
+  // the snapshot), and Electron then feeds its build-time js2c cache for
+  // those same electron/js2c/* bundles. The id sets overlap on the js2c
+  // bundles, so merge additively (don't drop the node-internal entries) and
+  // use insert_or_assign so the later, build-time entry wins for shared ids.
+  // Both caches are built against this isolate, so either is valid.
+  code_cache_->map.reserve(code_cache_->map.size() + in.size());
   for (auto const& [id, data] : in) {
-    auto result = code_cache_->map.emplace(id, data);
-    USE(result.second);
-    DCHECK(result.second);
+    code_cache_->map.insert_or_assign(id, data);
   }
   code_cache_->has_code_cache = true;
 }
diff --git a/src/node_external_reference.h b/src/node_external_reference.h
index 5ce9ec0a8c207b1452e7cef0aff2441a4e99d161..e474b0dab727a7019aa146cac53816596e031331 100644
--- a/src/node_external_reference.h
+++ b/src/node_external_reference.h
@@ -42,6 +42,11 @@ class ExternalReferenceRegistry {
   // Registers both the underlying function pointer
   // and the corresponding CFunctionInfo.
   void Register(const v8::CFunction& c_func) {
+    // Since the V8 change to store the v8::CFunction directly in
+    // FunctionTemplateInfo (wrapped in a Foreign), the snapshot serializer
+    // encodes the CFunction object address itself, so it must also be a
+    // registered external reference.
+    RegisterT(&c_func);
     RegisterT(c_func.GetAddress());
     RegisterT(c_func.GetTypeInfo());
   }
